# =============================================
#  Shopee Seller AI — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha
# =============================================

# Banco de dados (copie do painel Railway -> PostgreSQL -> Connect)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# JWT — chave secreta para tokens de autenticação (gere uma string aleatória longa)
JWT_SECRET="sua_chave_secreta_muito_longa_aqui_troque_isso"
JWT_EXPIRES_IN="7d"

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI (DALL-E 3 + Fine-tuning) — https://platform.openai.com
OPENAI_API_KEY="sk-..."

# Cloudinary (armazenamento de imagens) — https://cloudinary.com
CLOUDINARY_CLOUD_NAME="seu_cloud_name"
CLOUDINARY_API_KEY="sua_api_key"
CLOUDINARY_API_SECRET="seu_api_secret"

# Servidor
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
